# --- NEXUS CORE Frontend :: Environment Configuration ---

# Base URL of the NEXUS CORE FastAPI backend (no trailing slash).
NEXT_PUBLIC_NEXUS_API_URL=http://localhost:8000

# --- Clerk ---
# From your Clerk dashboard (Configure > API Keys).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_key_here

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Must match the backend's CLERK_ISSUER for the two to trust the same tokens
# (see nexus-core/.env.example on the backend).

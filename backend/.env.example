# --- NEXUS CORE :: Environment Configuration ---

# Your Qwen Cloud (DashScope) API key. Required.
QWEN_API_KEY=sk-your-qwen-cloud-api-key-here

# Qwen Cloud compatible-mode base URL. Do not change unless using a regional endpoint.
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Model used for both ELLA (proposer) and JANE (corrector) to optimize token usage/latency.
QWEN_MODEL=qwen-turbo

# Path to the local SQLite audit database (created automatically on first run).
NEXUS_DB_PATH=nexus_audit.db

# Max number of JANE correction attempts before a task is hard-rejected.
MAX_CORRECTION_ATTEMPTS=2

# Timeout (seconds) for each Qwen Cloud API call.
QWEN_TIMEOUT_SECONDS=30

# --- Auth (optional) ---
# If left blank, auth is fully disabled and every request is treated as
# DEMO_USER_ID below -- lets the backend run standalone without Clerk.
# Set this to your Clerk instance issuer (e.g. https://your-app.clerk.accounts.dev)
# to require a valid Clerk-issued JWT (Authorization: Bearer <token>) on every request.
CLERK_ISSUER=

# Only needed if your JWKS URL differs from <CLERK_ISSUER>/.well-known/jwks.json
CLERK_JWKS_URL=

# User id used for every request when auth is disabled.
DEMO_USER_ID=demo-user

# --- Tools ---
# Timeout (seconds) for the web_search tool (DuckDuckGo Instant Answer API).
WEB_SEARCH_TIMEOUT_SECONDS=10
